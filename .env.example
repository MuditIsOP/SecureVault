# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR-KEY-HERE\n-----END RSA PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/securevault
MONGODB_DB_NAME=securevault

# Security — Challenge Token
# Used for temporary auth tokens during security question/backup code flows
CHALLENGE_TOKEN_SECRET=replace-with-random-256-bit-hex-string

# Rate Limiting (optional — Firebase handles this via rules)
# RATE_LIMIT_AUTH=5
# RATE_LIMIT_VAULT=30
# RATE_LIMIT_SYNC=60
