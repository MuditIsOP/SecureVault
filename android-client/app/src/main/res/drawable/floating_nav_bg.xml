<?xml version="1.0" encoding="utf-8"?>
<!-- Floating nav bar background — frosted glass effect, high opacity -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="28dp" />
    <!-- High opacity frosted glass — NOT transparent -->
    <solid android:color="#F01C1B1F" />
    <stroke
        android:width="1dp"
        android:color="#20D0BCFF" />
</shape>
