<?xml version="1.0" encoding="utf-8"?>
<!--
  SCR-GEN-01 — Password Generator Fragment (Premium Redesign)
  Grouped cards, no divider lines, modern Material 3 aesthetic.
  PRD F-GEN-01: Length Slider, toggles, Strength Meter, Copy/Generate.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <!-- ═══════════════ Generated Password Display ═══════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_generated_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/color_on_surface"
                    android:textSize="22sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:lineSpacingExtra="6dp"
                    android:breakStrategy="balanced"
                    android:minLines="2"
                    android:text="Tap Generate" />

                <!-- Strength Meter -->
                <ProgressBar
                    android:id="@+id/progress_strength"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="20dp"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tv_strength_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="@color/color_on_surface_variant"
                    android:textSize="13sp"
                    android:text="Strength: —" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════ Length Control ═══════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Password Length"
                        android:textColor="@color/color_on_surface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_length_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/color_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:minWidth="36dp"
                        android:text="16" />

                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_length"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:valueFrom="8"
                    android:valueTo="64"
                    android:value="16"
                    android:stepSize="1"
                    app:trackColorActive="@color/color_primary"
                    app:trackColorInactive="@color/color_surface_variant"
                    app:thumbColor="@color/color_primary"
                    app:haloColor="#40D0BCFF" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════ Character Types ═══════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Character Types"
                    android:textColor="@color/color_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_uppercase"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Uppercase (A-Z)"
                    android:textColor="@color/color_on_surface"
                    android:textSize="14sp"
                    android:checked="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_lowercase"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Lowercase (a-z)"
                    android:textColor="@color/color_on_surface"
                    android:textSize="14sp"
                    android:checked="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_numbers"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Numbers (0-9)"
                    android:textColor="@color/color_on_surface"
                    android:textSize="14sp"
                    android:checked="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_symbols"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Symbols (!@#$%...)"
                    android:textColor="@color/color_on_surface"
                    android:textSize="14sp"
                    android:checked="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_exclude_similar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Exclude Similar (i, l, 1, o, 0)"
                    android:textColor="@color/color_on_surface"
                    android:textSize="14sp"
                    android:checked="false" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════ Action Buttons ═══════════════ -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_generate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Generate Password"
            android:textColor="@color/color_on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/color_primary"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_key"
            app:iconTint="@color/color_on_primary"
            app:iconSize="20dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Copy to Clipboard"
            android:textColor="@color/color_primary"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/color_surface_variant"
            app:strokeWidth="1dp"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_copy"
            app:iconTint="@color/color_primary"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

    </LinearLayout>

</ScrollView>
