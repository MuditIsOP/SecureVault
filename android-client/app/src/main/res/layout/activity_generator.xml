<?xml version="1.0" encoding="utf-8"?>
<!--
  SCR-GEN-01 — Password Generator Screen Layout
  PRD F-GEN-01 AC#2: Length Slider (8-64), toggles (Upper/Lower/Numbers/Symbols/ExcludeSimilar)
  PRD F-GEN-01 AC#3: Strength Meter, Copy Button, Use Password button
  Design.md §3.2: Strength Meter, monospace font, success green (#81C784)
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top App Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_generator"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginBottom="16dp"
            app:title="Password Generator"
            app:titleTextColor="@color/color_on_surface"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/color_on_surface" />

        <!-- Generated Password Display — monospace font per Design.md §3.2 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/color_surface_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_generated_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/color_on_surface"
                    android:textSize="20sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="4dp"
                    android:breakStrategy="balanced"
                    android:minLines="2"
                    android:text="Tap Generate" />

                <!-- Strength Meter — PRD F-GEN-01 AC#3 -->
                <ProgressBar
                    android:id="@+id/progress_strength"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tv_strength_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:textColor="@color/color_secondary"
                    android:textSize="13sp"
                    android:text="Strength: —" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Length Slider — PRD F-GEN-01 AC#2 "Length Slider (8 to 64)" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password Length"
            android:textColor="@color/color_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_length"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="8"
                android:valueTo="64"
                android:value="16"
                android:stepSize="1"
                app:trackColorActive="@color/color_primary"
                app:thumbColor="@color/color_primary" />

            <TextView
                android:id="@+id/tv_length_value"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/color_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="16" />

        </LinearLayout>

        <!-- Character Type Toggles — PRD F-GEN-01 AC#2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Character Types"
            android:textColor="@color/color_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Uppercase toggle -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_uppercase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Uppercase (A-Z)"
            android:textColor="@color/color_on_surface"
            android:checked="true"
            android:paddingVertical="4dp" />

        <!-- Lowercase toggle -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_lowercase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lowercase (a-z)"
            android:textColor="@color/color_on_surface"
            android:checked="true"
            android:paddingVertical="4dp" />

        <!-- Numbers toggle -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_numbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Numbers (0-9)"
            android:textColor="@color/color_on_surface"
            android:checked="true"
            android:paddingVertical="4dp" />

        <!-- Symbols toggle -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_symbols"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Symbols (!@#$%...)"
            android:textColor="@color/color_on_surface"
            android:checked="true"
            android:paddingVertical="4dp" />

        <!-- Exclude Similar toggle — PRD F-GEN-01 AC#2 -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_exclude_similar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exclude Similar (i, l, 1, L, o, 0, O)"
            android:textColor="@color/color_on_surface"
            android:checked="false"
            android:paddingVertical="4dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <!-- Generate Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_generate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Generate Password"
                android:textColor="@color/color_on_primary"
                app:backgroundTint="@color/color_primary"
                app:cornerRadius="12dp" />

            <!-- Copy Button — PRD F-GEN-01 AC#3 "Copy Button" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_copy"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Copy to Clipboard"
                android:textColor="@color/color_primary"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/color_primary"
                app:cornerRadius="12dp" />

            <!-- Use Password — PRD F-GEN-01 AC#3 "Use Password button
                 (only visible when opened from Add/Edit Screen)" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_use_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Use This Password"
                android:textColor="@color/color_on_primary"
                app:backgroundTint="#81C784"
                app:cornerRadius="12dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
