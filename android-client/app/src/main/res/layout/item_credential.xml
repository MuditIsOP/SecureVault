<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_credential"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/color_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_surface_variant"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Avatar container: favicon overlays letter fallback -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp">

            <!-- Letter fallback (always present) -->
            <TextView
                android:id="@+id/tv_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textColor="@color/color_on_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/circle_avatar_bg" />

            <!-- Favicon from web (loaded over letter avatar) -->
            <ImageView
                android:id="@+id/iv_favicon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Website icon" />
        </FrameLayout>

        <!-- Name + Username -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tv_credential_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_credential_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Favorite star -->
        <ImageView
            android:id="@+id/iv_favorite_star"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_star"
            app:tint="#FFD700"
            android:contentDescription="Favorite"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
