<?xml version="1.0" encoding="utf-8"?>
<!--
  SCR-VLT-01 — Individual password list entry card
  PRD F-VAULT-01 AC#2: "Website Favicon (or letter fallback avatar),
    Website/Entry Name, Username/Email, and a Star (Favorite) indicator."
  Design.md §2.1: surface #1C1B1F, on-surface #E6E1E5, secondary #CCC2DC
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_credential"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/color_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_surface_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Letter fallback avatar — PRD F-VAULT-01 AC#2 -->
        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textColor="@color/color_on_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/circle_avatar_bg" />

        <!-- Name and Username/Email -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Website/Entry Name — PRD F-VAULT-01 AC#2 -->
            <TextView
                android:id="@+id/tv_credential_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Username/Email — PRD F-VAULT-01 AC#2 -->
            <TextView
                android:id="@+id/tv_credential_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_secondary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Star (Favorite) indicator — PRD F-VAULT-01 AC#2 -->
        <ImageView
            android:id="@+id/iv_favorite_star"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/btn_star_big_on"
            android:contentDescription="Favorite"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
