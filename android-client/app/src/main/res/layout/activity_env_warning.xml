<?xml version="1.0" encoding="utf-8"?>
<!--
  SCR-ATH-05 — Insecure Host Warning Screen Layout.
  Design.md: background #141218, surface #1D1B20, warning #E3A857
  Referenced by EnvWarningActivity.kt
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Loading state — Scanning checks -->
    <ProgressBar
        android:id="@+id/progress_scanning"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Warnings content -->
    <LinearLayout
        android:id="@+id/layout_warnings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Warning header -->
        <TextView
            android:id="@+id/tv_warning_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:textColor="@color/color_warning"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_warning_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/color_on_surface_variant"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Root warning card — PRD F-DEV-02 AC#2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_root_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/color_surface"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/color_warning"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_root_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/color_warning"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_root_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="@color/color_on_surface_variant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Debug warning card — PRD F-DEV-02 AC#3 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_debug_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/color_surface"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/color_warning"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_debug_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/color_warning"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_debug_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="@color/color_on_surface_variant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

        <!-- Continue Anyway button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue_anyway"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Continue Anyway"
            android:textColor="@color/color_warning"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</FrameLayout>
