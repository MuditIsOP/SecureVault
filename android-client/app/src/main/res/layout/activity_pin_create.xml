<?xml version="1.0" encoding="utf-8"?>
<!--
  SCR-ONB-03 — PIN Creation Screen Layout.
  Design.md §3.2: Numeric Keypad (3x4 grid), PIN Dot Indicators (6 dots)
  Referenced by PinCreateActivity.kt
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:gravity="center_horizontal">

    <!-- Title — toggles between "Create your PIN" and "Confirm your PIN" -->
    <TextView
        android:id="@+id/tv_pin_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create your PIN"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:textColor="@color/color_on_surface"
        android:layout_marginTop="80dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter a 6-digit PIN to secure your vault"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="@color/color_on_surface_variant"
        android:layout_marginTop="8dp" />

    <!-- PIN dot indicators — Design.md §3.2 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp">
        <View android:id="@+id/dot_1" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot_2" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot_3" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot_4" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot_5" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot_6" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/pin_dot_empty" />
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Numeric keypad — Design.md §3.2 (3x4 grid) -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_1"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="1"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_2"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="2"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_3"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="3"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_4"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="4"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_5"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="5"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_6"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="6"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_7"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="7"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_8"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="8"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_9"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="9"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />

        <!-- Bottom row: Clear, 0, Delete -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_clear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="CLR"
            android:textSize="14sp"
            android:textColor="@color/color_on_surface_variant" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_0"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="0"
            android:textSize="24sp"
            android:textColor="@color/color_on_surface" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/key_delete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:text="DEL"
            android:textSize="14sp"
            android:textColor="@color/color_on_surface_variant" />
    </GridLayout>

</LinearLayout>
