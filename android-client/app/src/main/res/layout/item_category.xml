<?xml version="1.0" encoding="utf-8"?>
<!--
  Category list item — Premium redesign
  Folder icon circle + name + count badge + delete action
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/color_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Folder icon circle -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_nav_categories"
            app:tint="@color/color_primary"
            android:background="@drawable/circle_icon_bg"
            android:contentDescription="Category" />

        <!-- Name + count -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tv_category_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_password_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Default badge pill -->
        <TextView
            android:id="@+id/tv_default_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default"
            android:textColor="@color/color_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/circle_icon_bg"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <!-- Delete button — hidden for defaults -->
        <ImageButton
            android:id="@+id/btn_delete_category"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/color_error"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete category"
            android:visibility="visible" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
