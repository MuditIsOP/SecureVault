<?xml version="1.0" encoding="utf-8"?>
<!--
  SCR-DEV-01 — Active Devices Screen Layout.
  Design.md: background #141218, error #F2B8B5
  Referenced by ActiveDevicesActivity.kt
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_devices"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_surface"
        app:title="Active Devices"
        app:titleTextColor="@color/color_on_surface"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/color_on_surface" />

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Device list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_devices"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp"
            android:visibility="gone" />

        <!-- Loading state -->
        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No active sessions found."
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@color/color_on_surface_variant"
            android:visibility="gone" />

        <!-- Error state -->
        <TextView
            android:id="@+id/tv_error_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Could not load device list. Pull to refresh."
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="@color/color_error"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
