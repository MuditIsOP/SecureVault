<?xml version="1.0" encoding="utf-8"?>
<!--
  SCR-VLT-02 — Add/Edit Password Screen
  Screens.md: Name, Username/Email, Password, Website URL, Category dropdown,
              Generate Password shortcut, Save button
  Design.md §2.1: background #141218, surface #1C1B1F, surface-variant #49454F
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title — Design.md §2.2 Headline Medium 28sp -->
        <TextView
            android:id="@+id/tv_screen_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Password"
            android:textColor="@color/color_on_surface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <!-- Name input — PRD F-VAULT-02 AC#1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundColor="@color/color_surface"
            app:boxStrokeColor="@color/color_surface_variant"
            app:hintTextColor="@color/color_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Entry Name"
                android:textColor="@color/color_on_surface"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Username/Email input — PRD F-VAULT-02 AC#1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundColor="@color/color_surface"
            app:boxStrokeColor="@color/color_surface_variant"
            app:hintTextColor="@color/color_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_username_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Username / Email"
                android:textColor="@color/color_on_surface"
                android:inputType="textEmailAddress"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password input + Generate button — PRD F-VAULT-02 AC#1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:boxBackgroundColor="@color/color_surface"
                app:boxStrokeColor="@color/color_surface_variant"
                app:hintTextColor="@color/color_secondary"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    android:textColor="@color/color_on_surface"
                    android:inputType="textPassword"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Generate Password button — SCR-VLT-02: "Generate Password shortcut" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_generate_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generate"
                style="@style/Widget.Material3.Button.TonalButton"
                app:backgroundTint="@color/color_surface_variant" />

        </LinearLayout>

        <!-- Website URL input — PRD F-VAULT-02 AC#1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_website_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundColor="@color/color_surface"
            app:boxStrokeColor="@color/color_surface_variant"
            app:hintTextColor="@color/color_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_website_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Website URL"
                android:textColor="@color/color_on_surface"
                android:inputType="textUri"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Category dropdown — PRD F-VAULT-02 AC#1, SCR-VLT-02 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxBackgroundColor="@color/color_surface"
            app:boxStrokeColor="@color/color_surface_variant"
            app:hintTextColor="@color/color_secondary">

            <AutoCompleteTextView
                android:id="@+id/act_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Category"
                android:textColor="@color/color_on_surface"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save button — SCR-VLT-02: "Save entry" -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save"
            app:backgroundTint="@color/color_primary"
            android:textColor="@color/color_on_primary"
            android:textSize="16sp"
            app:cornerRadius="16dp" />

        <!-- Loading spinner — SCR-VLT-02 Loading state -->
        <ProgressBar
            android:id="@+id/progress_saving"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
